{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://colortouch.dev/schemas/user-answers.json",
  "title": "UserAnswers",
  "description": "End user's in-app preference questionnaire, submitted by the SDK when requesting a PersonalizedPalette.",
  "type": "object",
  "additionalProperties": false,
  "required": ["user_id", "visual_preference", "tone_of_voice", "motion_sensitivity", "personality_traits"],
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "visual_preference": {
      "type": "string",
      "enum": ["minimal", "vibrant", "professional", "playful"]
    },
    "tone_of_voice": {
      "type": "string",
      "enum": ["formal", "casual", "playful", "serious"]
    },
    "motion_sensitivity": {
      "type": "string",
      "enum": ["none", "mild", "high"]
    },
    "personality_traits": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 40 },
      "maxItems": 10,
      "uniqueItems": true
    }
  }
}
