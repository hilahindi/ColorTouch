{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://colortouch.dev/schemas/color-scheme.json",
  "title": "Material3ColorScheme",
  "description": "Mirrors androidx.compose.material3.ColorScheme field-for-field so the SDK can construct a ColorScheme directly from this object with no translation layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "primary", "onPrimary", "primaryContainer", "onPrimaryContainer",
    "inversePrimary",
    "secondary", "onSecondary", "secondaryContainer", "onSecondaryContainer",
    "tertiary", "onTertiary", "tertiaryContainer", "onTertiaryContainer",
    "background", "onBackground",
    "surface", "onSurface",
    "surfaceVariant", "onSurfaceVariant",
    "surfaceTint",
    "inverseSurface", "inverseOnSurface",
    "error", "onError", "errorContainer", "onErrorContainer",
    "outline", "outlineVariant",
    "scrim",
    "surfaceBright", "surfaceDim",
    "surfaceContainer", "surfaceContainerHigh", "surfaceContainerHighest",
    "surfaceContainerLow", "surfaceContainerLowest"
  ],
  "properties": {
    "primary":                   { "$ref": "#/definitions/hexColor" },
    "onPrimary":                 { "$ref": "#/definitions/hexColor" },
    "primaryContainer":          { "$ref": "#/definitions/hexColor" },
    "onPrimaryContainer":        { "$ref": "#/definitions/hexColor" },
    "inversePrimary":            { "$ref": "#/definitions/hexColor" },
    "secondary":                 { "$ref": "#/definitions/hexColor" },
    "onSecondary":               { "$ref": "#/definitions/hexColor" },
    "secondaryContainer":        { "$ref": "#/definitions/hexColor" },
    "onSecondaryContainer":      { "$ref": "#/definitions/hexColor" },
    "tertiary":                  { "$ref": "#/definitions/hexColor" },
    "onTertiary":                { "$ref": "#/definitions/hexColor" },
    "tertiaryContainer":         { "$ref": "#/definitions/hexColor" },
    "onTertiaryContainer":       { "$ref": "#/definitions/hexColor" },
    "background":                { "$ref": "#/definitions/hexColor" },
    "onBackground":              { "$ref": "#/definitions/hexColor" },
    "surface":                   { "$ref": "#/definitions/hexColor" },
    "onSurface":                 { "$ref": "#/definitions/hexColor" },
    "surfaceVariant":            { "$ref": "#/definitions/hexColor" },
    "onSurfaceVariant":          { "$ref": "#/definitions/hexColor" },
    "surfaceTint":               { "$ref": "#/definitions/hexColor" },
    "inverseSurface":            { "$ref": "#/definitions/hexColor" },
    "inverseOnSurface":          { "$ref": "#/definitions/hexColor" },
    "error":                     { "$ref": "#/definitions/hexColor" },
    "onError":                   { "$ref": "#/definitions/hexColor" },
    "errorContainer":            { "$ref": "#/definitions/hexColor" },
    "onErrorContainer":          { "$ref": "#/definitions/hexColor" },
    "outline":                   { "$ref": "#/definitions/hexColor" },
    "outlineVariant":            { "$ref": "#/definitions/hexColor" },
    "scrim":                     { "$ref": "#/definitions/hexColor" },
    "surfaceBright":             { "$ref": "#/definitions/hexColor" },
    "surfaceDim":                { "$ref": "#/definitions/hexColor" },
    "surfaceContainer":          { "$ref": "#/definitions/hexColor" },
    "surfaceContainerHigh":      { "$ref": "#/definitions/hexColor" },
    "surfaceContainerHighest":   { "$ref": "#/definitions/hexColor" },
    "surfaceContainerLow":       { "$ref": "#/definitions/hexColor" },
    "surfaceContainerLowest":    { "$ref": "#/definitions/hexColor" }
  },
  "definitions": {
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "description": "6-digit opaque RGB hex color, e.g. #6750A4"
    }
  }
}
